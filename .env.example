GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Backend/Public URL consumed by Spring CORS + OAuth redirect handler
APP_FRONTEND_URL=http://localhost:5173
APP_CORS_ALLOW_LOCALHOST_ORIGINS=true

# PostgreSQL (required for "default" profile)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password

# S3 attachment storage (required for default)
AWS_S3_BUCKET=your-bucket
AWS_REGION=eu-central-1
AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.eu-central-1.amazonaws.com
